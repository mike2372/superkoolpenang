rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net: Default deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable global functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Appointment Schema Validator
    function isValidAppointment(data) {
      return data.id is string
        && data.userId is string
        && data.clientName is string
        && data.clientName.size() <= 100
        && data.clientPhone is string
        && data.clientPhone.size() <= 30
        && data.clientEmail is string
        && data.clientEmail.size() <= 100
        && data.clientAddress is string
        && data.clientAddress.size() <= 500
        && data.clientArea is string
        && data.serviceType is string
        && data.unitsCount is number
        && data.unitsCount >= 1
        && data.unitsCount <= 50
        && data.acType is string
        && data.acBrand is string
        && data.acHorsepower is string
        && data.serviceDate is string
        && data.serviceTimeSlot is string
        && data.estimatePrice is number
        && data.estimatePrice >= 0
        && data.status is string
        && (data.status == 'pending' || data.status == 'confirmed' || data.status == 'assigned' || data.status == 'completed' || data.status == 'cancelled');
    }

    // Appointments match logic
    match /appointments/{appointmentId} {
      // Allow single read and search queries if the requester owns the appointment, or if we are signed in.
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || request.auth.token.email_verified == true);
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || request.auth.token.email_verified == true);

      // Create validation
      allow create: if isSignedIn() 
        && isValidId(appointmentId)
        && isValidAppointment(incoming())
        && incoming().userId == request.auth.uid
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;

      // Update validation - separated by specific action trees using affectedKeys().hasOnly
      allow update: if isSignedIn()
        && isValidId(appointmentId)
        && isValidAppointment(incoming())
        && incoming().updatedAt == request.time
        && incoming().createdAt == existing().createdAt
        && incoming().userId == existing().userId
        && (
          // Action 1: Customer cancelling their own booking
          (existing().userId == request.auth.uid && incoming().status == 'cancelled' && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']))
          ||
          // Action 2: Staff updating status or assigning technician
          (request.auth.token.email_verified == true && (
            incoming().diff(existing()).affectedKeys().hasOnly(['status', 'technicianName', 'updatedAt'])
          ))
        );

      // System records should not be arbitrarily deleted
      allow delete: if false;
    }
  }
}
